BIANCO_SITE_ADDRESS=:80
# Secure by default: expose Bianco only to a reverse proxy on this host.
BIANCO_BIND_ADDRESS=127.0.0.1
BIANCO_HTTP_PORT=8080
BIANCO_SYNC_TOKEN=replace-with-a-long-random-secret
BIANCO_SECRET_KEY=replace-with-an-independent-secret-of-at-least-32-characters
BIANCO_AUTH_USER=bianco
# Argon2 is recommended. Generate with: ./scripts/hash-password.sh
# Set CONTAINER_RUNTIME=podman when Docker is not installed.
# Existing Caddy bcrypt hashes remain supported for migration.
BIANCO_AUTH_PASSWORD_HASH=
BIANCO_SESSION_COOKIE_SECURE=true
BIANCO_SESSION_MAX_AGE_SECONDS=2592000
BIANCO_AUTH_RATE_LIMIT_ATTEMPTS=10
BIANCO_AUTH_RATE_LIMIT_WINDOW_SECONDS=300
BIANCO_AI_PROVIDER=none
BIANCO_AI_WORKER_ENABLED=true
BIANCO_AI_WORKER_POLL_SECONDS=2
BIANCO_AI_WORKER_MAX_ATTEMPTS=5
BIANCO_MAX_UPLOAD_BYTES=10485760

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=

OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=

# Existing external Ollama instance, reachable from the API container.
OLLAMA_BASE_URL=
OLLAMA_MODEL=qwen3.5:9b-q8_0
