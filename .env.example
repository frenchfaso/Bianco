BIANCO_SITE_ADDRESS=:80
# Porte host; lasciare 80/443 nel deployment standard.
BIANCO_HTTP_PORT=80
BIANCO_HTTPS_PORT=443
BIANCO_SYNC_TOKEN=replace-with-a-long-random-secret
BIANCO_SECRET_KEY=replace-with-an-independent-secret-of-at-least-32-characters
BIANCO_AUTH_USER=bianco
# Generare con: docker run --rm -it caddy:2.11.4-alpine caddy hash-password
BIANCO_AUTH_PASSWORD_HASH=
BIANCO_AI_PROVIDER=none
BIANCO_AI_WORKER_ENABLED=true
BIANCO_AI_WORKER_POLL_SECONDS=2
BIANCO_AI_WORKER_MAX_ATTEMPTS=5
BIANCO_MAX_UPLOAD_BYTES=10485760

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=

OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=

# Istanza Ollama esterna, raggiungibile dal container API.
OLLAMA_BASE_URL=
OLLAMA_MODEL=qwen3.5:9b-q8_0
