BIANCO_SITE_ADDRESS=:80
# Porte host; lasciare 80/443 nel deployment standard.
BIANCO_HTTP_PORT=80
BIANCO_HTTPS_PORT=443
BIANCO_SYNC_TOKEN=replace-with-a-long-random-secret
BIANCO_AI_PROVIDER=none
BIANCO_MAX_UPLOAD_BYTES=10485760

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=

# Istanza Ollama esterna, raggiungibile dal container API.
OLLAMA_BASE_URL=
OLLAMA_MODEL=qwen3.5:9b-q8_0
